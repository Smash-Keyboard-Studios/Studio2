    - target: {fileID: 6499761872223000497, guid: a158166407669584697fa60594eb8c22,
        type: 3}
      propertyPath: m_Size.x
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 6499761872223000497, guid: a158166407669584697fa60594eb8c22,
        type: 3}
