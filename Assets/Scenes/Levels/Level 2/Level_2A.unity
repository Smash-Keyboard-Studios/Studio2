  m_EditorClassIdentifier: 
  dialogueText: {fileID: 1413781446}
  dialogue:
  - dialogueName: Priest
    dialogueText: 'And finally, the women from my own youth who asked for nothing
      more than the same rights afforded to them as were afforded to men, their passion
      moved them to action. And those same actions that have given men their liberty
      were enough to see them hanged. '
